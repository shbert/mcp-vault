# Caddyfile — Reverse Proxy WAF pour MCP Vault
#
# Architecture : Internet → Caddy+Coraza WAF (:8085) → mcp-vault (:8030)
#
# Sécurité L7 :
#   - Coraza WAF avec OWASP CoreRuleSet v4
#   - Protection contre injections SQL, XSS, LFI, RCE, SSRF
#   - Headers de sécurité (HSTS, nosniff, X-Frame-Options)
#   - Exceptions spécifiques pour les endpoints MCP et Admin API

{
	# IMPORTANT : coraza_waf doit être exécuté AVANT les autres handlers
	order coraza_waf first
	order rate_limit before coraza_waf

	# Désactiver l'API admin Caddy (sécurité)
	admin off
}

{$SITE_ADDRESS::8085} {

	# ── TLS (paramétrable) ─────────────────────────────────────────
	# Vide par défaut (prod : terminaison TLS en façade / vrai certificat).
	# En test E2E ACME : WAF_TLS_DIRECTIVE="tls internal" pour servir le
	# directory ACME en HTTPS (Caddy refuse l'ACME sur une CA en HTTP).
	{$WAF_TLS_DIRECTIVE:}

	# ── Rate Limiting — Protection brute-force et DoS ─────────────
	# 10 000 requêtes par 5 minutes par IP (~33 req/s soutenu)
	# SÉCURITÉ : empêche le brute-force de tokens et le DoS applicatif
	# Note : le protocole MCP (Streamable HTTP) génère 3-4 requêtes
	# HTTP par appel outil (POST init + GET SSE + POST call + DELETE).
	# Un agent actif fait 10-20 appels MCP/s = 30-80 req/s en burst.
	# La fenêtre de 5 min lisse les pics tout en protégeant contre
	# les attaques soutenues.
	rate_limit {
		zone mcp_vault {
			key    {remote_host}
			events 10000
			window 5m
		}
	}

	# ── WAF Coraza avec OWASP CRS ─────────────────────────────────
	coraza_waf {
		directives `
			Include /etc/coraza/coraza.conf
		`
	}

	# ── Reverse proxy vers MCP Vault ──────────────────────────────
	reverse_proxy mcp-vault:8030 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# Timeouts adaptés aux appels MCP (qui peuvent être longs)
		transport http {
			dial_timeout 10s
			response_header_timeout 120s
			read_timeout 120s
			write_timeout 120s
		}
	}

	# ── Headers de sécurité ────────────────────────────────────────
	header {
		# SÉCURITÉ V2-13 : HSTS — force HTTPS pour tous les sous-domaines
		# max-age=1 an, includeSubDomains pour couverture complète
		# Note : ignoré si pas de TLS, mais prêt pour la production
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		X-XSS-Protection "1; mode=block"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
		# Pas de header Server (fingerprinting)
		-Server
	}

	# ── CORS restrictif (P2-6) ─────────────────────────────────────
	# Bloque les requêtes cross-origin sauf depuis la même origine.
	# Le SPA admin est servi par le même serveur, donc pas besoin de CORS.
	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Methods "GET, POST, PUT, DELETE"
		header Access-Control-Allow-Headers "Authorization, Content-Type"
		header Access-Control-Max-Age "3600"
		# Pas de Access-Control-Allow-Origin → bloque toute origine cross-origin
		respond 204
	}

	# ── Logs ───────────────────────────────────────────────────────
	log {
		output stderr
		format console
		level INFO
	}
}
