# =============================================================================
# Configuration MCP Vault — Copier en .env et adapter
#
# Groupes :
#   1. Serveur MCP (transport, WAF)
#   2. Authentification
#   3. S3 (token store + vault storage sync)
#   4. OpenBao embedded
#   5. PKI interne (v0.5.x — optionnel)
#   6. Mission token enforcement (v0.6.0 — optionnel, standalone sans mcp-mission)
#   7. CLI — variables d'environnement (jamais dans .env, passer en export)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. Serveur MCP
# ─────────────────────────────────────────────────────────────────────────────

MCP_SERVER_NAME=mcp-vault
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8030

# FQDN publics par lesquels les clients MCP atteignent /mcp (séparés par virgules).
# OBLIGATOIRE en production derrière un reverse-proxy — sans cela, le SDK rejette
# le header Host public en HTTP 421 (cf. issue #3, protection anti-DNS-rebinding).
# Le loopback (localhost/127.0.0.1) est toujours autorisé automatiquement.
MCP_ALLOWED_HOSTS=vault.mcp.cloud-temple.app,my.vault.mcp.cloud-temple.app

# Origins HTTP supplémentaires (optionnel).
# "https://<fqdn>" est déjà dérivé pour chaque FQDN ci-dessus.
# MCP_ALLOWED_ORIGINS=

# ─────────────────────────────────────────────────────────────────────────────
# 2. WAF
# ─────────────────────────────────────────────────────────────────────────────

WAF_PORT=8085

# ─────────────────────────────────────────────────────────────────────────────
# 3. Authentification
# ─────────────────────────────────────────────────────────────────────────────

# Clé de bootstrap pour le premier accès admin (jeton initial de l'instance Vault).
# Utilisée aussi pour déchiffrer les clés unseal OpenBao stockées sur S3.
# ⚠️  OBLIGATOIRE de changer en production — minimum 32 caractères, entropie forte.
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(48))"
***REMOVED***

# ─────────────────────────────────────────────────────────────────────────────
# 4. S3 — Token Store + Vault Storage Sync
# ─────────────────────────────────────────────────────────────────────────────
# Mêmes credentials pour les deux usages (token store + sync OpenBao data).
# Compatible Dell ECS (SigV2/SigV4 hybride).

S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
S3_ACCESS_KEY_ID=your_access_key_here
S3_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=your-bucket-name
S3_REGION_NAME=fr1

# Forcer SigV4 sur les opérations data (PUT/GET/DELETE).
# false (défaut) = SigV2 legacy (Dell ECS). true = SigV4 (MinIO, VersityGW, AWS S3).
S3_FORCE_SIGV4=false

# Préfixe S3 pour le backup du file backend OpenBao (tar.gz périodique).
# Modifier pour isoler plusieurs instances sur le même bucket.
VAULT_S3_PREFIX=_storage

# Intervalle de sync S3 en secondes (défaut 60s).
VAULT_S3_SYNC_INTERVAL=60

# ─────────────────────────────────────────────────────────────────────────────
# 5. OpenBao embedded
# ─────────────────────────────────────────────────────────────────────────────

# Adresse interne du processus OpenBao (ne jamais exposer hors du conteneur).
OPENBAO_ADDR=http://127.0.0.1:8200

# Paramètres Shamir (1/1 = single key, adapté pour un seul opérateur).
OPENBAO_SHARES=1
OPENBAO_THRESHOLD=1

# Répertoires internes OpenBao (montés depuis les volumes Docker).
OPENBAO_DATA_DIR=/openbao/file
OPENBAO_CONFIG_DIR=/openbao/config

# ─────────────────────────────────────────────────────────────────────────────
# 6. PKI interne (v0.5.x — optionnel)
# ─────────────────────────────────────────────────────────────────────────────
# Si vide, la PKI n'est pas initialisée au démarrage.
# Activer via pki_ca_setup (outil MCP ou POST /admin/api/pki/setup).

# URL publique de base pour les CDPs ACME et le cluster path OpenBao PKI.
# Vide (défaut) = déduit du premier FQDN de MCP_ALLOWED_HOSTS (https://<fqdn>).
# Override en test Docker pour utiliser l'URL interne : http://mcp-vault:8030
# Doit être http:// ou https://.
# PKI_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# 7. Mission token enforcement (v0.6.0 — optionnel)
#
# Anti-confused-deputy C18 (alignement mcp-mission/mcp-vault).
# Toutes ces variables sont OPTIONNELLES.
# Par défaut : zéro impact sur les déploiements standalone (sans mcp-mission).
# ─────────────────────────────────────────────────────────────────────────────

# Active le hard-reject JWT dans secret_consume.
# false (défaut) = log warning si JWT invalide, continue (migration progressive).
# true           = hard-reject 401/403 sur toute violation JWT ou binding.
# ⚠️  Mettre à true uniquement après avoir configuré MISSION_JWKS_URL et MISSION_TOKEN_AUD.
# ENFORCE_MISSION_TOKEN_VALIDATION=false

# URL du JWKS public de mcp-mission (endpoint /.well-known/jwks.json).
# Vide = validation JWT désactivée (mode standalone compatible).
# Ex : https://mcp-mission.cloud-temple.app/.well-known/jwks.json
# MISSION_JWKS_URL=

# Audience attendue dans le JWT mission_token (anti-confused-deputy).
# Doit correspondre à l'aud JWT configuré côté mcp-mission pour cette instance Vault.
# Ex : mcp-vault:prod:v1  ou  vault.mcp.cloud-temple.app
# Vide = la vérification aud est désactivée (non recommandé en production).
# MISSION_TOKEN_AUD=

# TTL du cache JWKS en secondes.
# 60s (défaut) : bon compromis révocation rapide / performance.
# MISSION_JWKS_CACHE_TTL=60

# Nombre max de refreshes JWKS par minute (rate-limit anti-DoS).
# MISSION_JWKS_MAX_REFRESH_PER_MIN=3

# Tolérance clock skew entre services (JWT leeway en secondes).
# MISSION_TOKEN_LEEWAY_SECONDS=10

# URL de vérification du statut de mission (mcp-mission status endpoint).
# Template : {mission_id} est remplacé dynamiquement.
# Vide = vérification mission active désactivée.
# Ex : https://mcp-mission.cloud-temple.app/api/v1/missions/{mission_id}/status
# MISSION_STATUS_URL=

# TTL du cache de statut de mission en secondes (court = fail-close rapide).
# 5s (défaut) : fenêtre maximale de 5s après abort/close d'une mission.
# MISSION_STATUS_CACHE_TTL=5

# ─────────────────────────────────────────────────────────────────────────────
# 8. CLI — tokens sensibles (NE PAS mettre dans .env — exporter avant la commande)
#
# Ces variables sont lues par le CLI mais ne doivent PAS être stockées en dur
# dans .env car elles changent à chaque opération (single-use, TTL court).
# ─────────────────────────────────────────────────────────────────────────────

# Token de déballage OpenBao pour secret_consume (single-use, expire rapidement).
# Usage : VAULT_WRAP_TOKEN=hvs.CAES... mcp-vault secret consume <operation_id>
# VAULT_WRAP_TOKEN=

# JWT mission_token ES256 pour secret_consume (requis si ENFORCE=true).
# Usage : VAULT_MISSION_TOKEN=eyJ... mcp-vault secret consume <operation_id>
# VAULT_MISSION_TOKEN=
