# =============================================================================
# Configuration MCP Vault — Copier en .env et adapter
# =============================================================================

# --- Serveur MCP ---
MCP_SERVER_NAME=mcp-vault
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8030

# --- Transport security (protection anti-DNS-rebinding du SDK MCP) ---
# FQDN publics par lesquels les clients MCP atteignent /mcp, séparés par des virgules.
# OBLIGATOIRE en production derrière un reverse-proxy : sans cela, le SDK rejette le
# header Host public en HTTP 421 « Invalid Host header » (cf. issue #3).
# Le loopback (localhost/127.0.0.1) est toujours autorisé en plus automatiquement.
MCP_ALLOWED_HOSTS=vault.mcp.cloud-temple.app,my.vault.mcp.cloud-temple.app
# Origins HTTP supplémentaires (optionnel). "https://<fqdn>" est déjà dérivé pour chaque
# FQDN ci-dessus ; cette variable en AJOUTE d'autres (elle ne les remplace pas).
# MCP_ALLOWED_ORIGINS=

# --- WAF ---
WAF_PORT=8085

# --- Auth ---
# Clé de bootstrap pour le premier accès admin.
# ⚠️  Changer en production ! (minimum 64 caractères aléatoires)
***REMOVED***

# --- S3 Token Store ---
# Persistance des tokens d'accès MCP sur S3.
S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
S3_ACCESS_KEY_ID=your_access_key_here
S3_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=your-bucket-name
S3_REGION_NAME=fr1

# --- OpenBao ---
# Configuration du moteur de secrets OpenBao embedded.
OPENBAO_ADDR=http://127.0.0.1:8200
OPENBAO_SHARES=1
OPENBAO_THRESHOLD=1
OPENBAO_DATA_DIR=/openbao/file
OPENBAO_CONFIG_DIR=/openbao/config

# --- S3 Vault Storage ---
# Sync du file backend OpenBao vers S3.
# Utilise les mêmes credentials S3 que le token store (même bucket, préfixe différent).
VAULT_S3_PREFIX=_storage
VAULT_S3_SYNC_INTERVAL=60
